{
  "name": "envx",
  "version": "0.2.0",
  "description": "Prevent env drift in PRs, generate env schema/types, and guard against leaked secrets.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "envx": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format esm --platform node --sourcemap",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "diff": "^5.2.0",
    "dotenv": "^16.6.1",
    "fast-glob": "^3.3.3",
    "gradient-string": "^2.0.2",
    "prompts": "^2.4.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/diff": "^5.2.0",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
